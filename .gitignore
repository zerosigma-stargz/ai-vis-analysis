# ── Dokumentasi internal (jangan di-publish ke GitHub) ──────────────────────
# Hanya README.md yang boleh publik
DESIGN_UPDATES.md
FILE_CHECKLIST.md
GITHUB_UPLOAD_GUIDE.md
REBRANDING_SUMMARY.md
SECURITY_CHECKLIST.md

# ── Data files yang mungkin berisi data sensitif ────────────────────────────
# Uncomment baris di bawah jika Anda tidak ingin commit file data besar
# *.csv
# *.xlsx
# *.xls
# *.parquet
# *.json
# *.pdf
# Catatan: tests/fixtures/*.csv AMAN di-commit (data dummy, bukan data nyata)

# ── Kiro IDE internal (exclude semua) ──────────────────────────────────────
# Seluruh folder .kiro dikecualikan — berisi konfigurasi IDE lokal,
# specs desain internal, dan settings yang tidak relevan untuk publik
.kiro/

# ── Streamlit ────────────────────────────────────────────────────────────────
# secrets.toml berisi API keys — JANGAN di-commit
.streamlit/secrets.toml
# config.toml AMAN di-commit (tidak berisi secrets)
# !.streamlit/config.toml

